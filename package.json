{
    "name": "minton-tennis",
    "version": "0.0.1",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "wrangler pages dev dist --local --port 8787",
        "build": "vite build",
        "deploy": "wrangler pages deploy dist",
        "db:reset": "rimraf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
        "db:migrate:local": "wrangler d1 migrations apply minton-tennis-db --local",
        "db:seed": "wrangler d1 execute minton-tennis-db --local --file=./seed.sql"
    },
    "dependencies": {
        "hono": "^4.1.0"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20240208.0",
        "@hono/vite-build": "^1.0.0",
        "@hono/vite-dev-server": "^0.9.0",
        "rimraf": "^5.0.0",
        "typescript": "^5.3.0",
        "vite": "^5.1.0",
        "wrangler": "^4.67.0"
    }
}